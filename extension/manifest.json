{
  "manifest_version": 3,
  "name": "PatternScout Prototype v0.1",
  "version": "0.1.0",
  "description": "Exposing manipulative design patterns on shopping websites.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://baget.ai/api/public/databases/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "extension/popup.html",
    "default_icon": "extension/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension/content.js"],
      "css": ["extension/styles.css"]
    }
  ],
  "background": {
    "service_worker": "extension/background.js"
  }
}
